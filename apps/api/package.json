    "@recepcionista/shared": "*",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "fastify": "^5.2.0",
    "googleapis": "^148.0.0",
    "luxon": "^3.5.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/luxon": "^3.4.2",
    "@types/node": "^22.10.2",
    "prisma": "^6.8.2",
    "tsx": "^4.19.2",
